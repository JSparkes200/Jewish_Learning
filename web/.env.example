# Copy to .env.local (never commit secrets). See ../docs/vercel-environment.md for Vercel dashboard steps.

# --- Site (client + metadata) ---
# Canonical URL for Open Graph / metadataBase (production), e.g. https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sentry (optional) ---
# Client + server error reporting. Create a Next.js project at https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=
# Server-only override (defaults to NEXT_PUBLIC_SENTRY_DSN if unset):
# SENTRY_DSN=
# Source maps in CI/Vercel (optional): SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN

# --- Ask Rabbi — POST /api/rabbi (server only; never expose to the client) ---
# OPENAI_API_KEY=
# OPENAI_RABBI_MODEL=gpt-4o-mini
# Optional: disable LightRAG (local subprocess + remote retrieve; “Context unavailable” in prompt)
# RABBI_USE_LIGHTRAG=0
# Remote retrieval (Railway FastAPI): base URL only, no trailing path — e.g. https://lightrag-api.up.railway.app
# RABBI_LIGHTRAG_RETRIEVE_URL=
# Shared secret; must match LIGHTRAG_RETRIEVE_SECRET on the Python service
# RABBI_LIGHTRAG_RETRIEVE_SECRET=
# Monorepo root if `next dev` cwd is not `web/` (usually unnecessary)
# RABBI_REPO_ROOT=
# Windows: PYTHON_EXE=py

# --- Developer mode (owner — unlocks all course gates in-browser) ---
# Must match the username/email you use to sign in on /developer. Generate a long random secret (openssl rand -hex 32).
# DEVELOPER_USERNAME=
# DEVELOPER_EMAIL=
# DEVELOPER_SESSION_SECRET=

# --- POST /api/auth/request-reset (legacy HTML password reset) ---
# JSON object on ONE line: lowercase username -> email. Template file (committed): data/auth-reset-email-map.example.json
AUTH_RESET_EMAIL_MAP={}

# Resend (https://resend.com) — optional; without RESEND_API_KEY the API still issues a code but does not email
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# If "1", response JSON may include _demoCode for debugging — only when NODE_ENV is not production
# DEMO_RESET_CODE=

# Comma-separated origins allowed to call /api/auth/* from a browser (e.g. https://user.github.io).
# Unset = Access-Control-Allow-Origin: * (legacy). Set in production when HTML app origin is fixed.
# AUTH_CORS_ORIGINS=

# --- POST /api/auth/confirm-reset + request-reset code storage ---
# Also used by GET/PUT/DELETE /api/progress (optional Learn backup in KV; see docs/cloud-progress.md)
# Link Vercel KV to the project; these are usually auto-filled by Vercel (do not commit values)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Navigation (client) ---
# If "true", hides the Developer link from the hamburger menu (production hardening).
# NEXT_PUBLIC_HIDE_DEVELOPER_NAV=

# --- POST /api/mcq-choices, /api/validate-hebrew-passage, /api/progress, /api/auth/*, GET /api/hebcal/snapshot ---
# Rate limits use the same Vercel KV when KV_REST_* are set. Without KV: skipped in development; auth routes return 503 in production.
# Lexicon: npm run extract:corpus-d

# --- POST /api/mcq-choices ---
# No extra env. Lexicon is web/data/corpus-d.ts (committed).
